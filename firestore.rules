rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS (Pillar 3 & 4) ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based helpers (Pillar 4)
    // Note: Auth tokens do not contain custom claims. We use a trusted User document.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isGlobalAdmin() {
      return isSignedIn() && (
        getUserData().get('globalRole', 'none') == 'admin' ||
        getUserData().get('role', 'none') == 'admin'
      );
    }

    function hasSchoolRole(schoolId, role) {
      let data = getUserData();
      return isAuthenticated() && (
        role in data.get('schoolAccess', {}).get(schoolId, []) ||
        (data.get('school', '') == schoolId && data.get('role', 'none') == role)
      );
    }

    function hasAuthorityRole(authorityId, role) {
      return isAuthenticated() && 
             getUserData().get('authorityAccess', {}).get(authorityId, 'none') == role;
    }

    function isAuthenticated() { return isSignedIn(); }

    // --- DEFAULT DENY (Global Safety Net) ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS ---
    match /users/{uid} {
      allow get: if isSignedIn() && (
        request.auth.uid == uid || 
        isGlobalAdmin() || 
        getUserData().get('school', '') == existing().get('school', 'none')
      );
      allow list: if isSignedIn() && (
        isGlobalAdmin() || 
        resource.data.get('school', '') == getUserData().get('school', 'none')
      );
      
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isGlobalAdmin()) && (
        isGlobalAdmin() || (
          !incoming().diff(existing()).affectedKeys().hasAny(['role', 'globalRole', 'schoolAccess', 'authorityAccess'])
        )
      );
    }

    // --- AUTHORITIES & SCHOOLS ---
    match /authorities/{authId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    // --- CASES (MASTER GATE) ---
    match /cases/{caseId} {
      
      // Validation Blueprint (Pillar 2)
      function isValidCase(data) {
        return data.keys().hasAll(['status', 'incidentDate', 'studentName', 'description', 'reporterUid', 'createdAt', 'school']) &&
               data.status is string && data.status.size() <= 20 &&
               data.incidentDate is string &&
               data.studentName is string && data.studentName.size() <= 100 &&
               data.description is string && data.description.size() <= 5000 &&
               data.reporterUid is string &&
               data.createdAt == request.time;
      }

      function canUserViewCase(caseData) {
        let userData = getUserData();
        return isGlobalAdmin() ||
               caseData.reporterUid == request.auth.uid ||
               caseData.assignedToUid == request.auth.uid ||
               caseData.get('assignedTeacherUid', '') == request.auth.uid ||
               (caseData.get('assignedTeam', '') != '' && caseData.assignedTeam == userData.get('team', 'none')) ||
               (isSignedIn() && caseData.get('reporterEmail', '') != '' && caseData.reporterEmail == userData.email) ||
               (caseData.get('schoolId', '') != '' && hasSchoolRole(caseData.schoolId, 'principal')) ||
               (caseData.get('authorityId', '') != '' && hasAuthorityRole(caseData.authorityId, 'authority')) ||
               // Legacy school name check
               (userData.get('role', 'none') == 'principal' && userData.get('school', '') == caseData.school);
      }

      // Query Enforcer (Pillar 8)
      allow get: if (
        (isSignedIn() && canUserViewCase(existing())) ||
        (existing().reporterUid == 'anonymous') // Anonymous reports are write-only for the reporter, but can be read if known ID?
        // Actually, anonymous reports should be private to admins/principals.
      );

      // If anonymous, they can't even get. Only principled/admins can.
      allow list: if isSignedIn() && canUserViewCase(resource.data);

      allow create: if (
        (isSignedIn() && incoming().reporterUid == request.auth.uid && isValidCase(incoming())) ||
        (!isSignedIn() && incoming().reporterUid == 'anonymous' && isValidCase(incoming()))
      );

      allow update: if isSignedIn() && (
        isGlobalAdmin() ||
        (canUserViewCase(existing()) && (
          // Action: assign
          (incoming().diff(existing()).affectedKeys().hasOnly(['assignedToUid', 'assignedTeacher', 'status', 'updatedAt']) && 
           (hasSchoolRole(existing().schoolId, 'principal') || isGlobalAdmin())) ||
          // Action: investigate
          (incoming().diff(existing()).affectedKeys().hasAny(['investigationText', 'investigationDate', 'status', 'updatedAt']) && 
           (existing().assignedToUid == request.auth.uid || isGlobalAdmin())) ||
          // Action: follow-up
          (incoming().diff(existing()).affectedKeys().hasAny(['followUpText', 'status', 'updatedAt']) && 
           (existing().assignedToUid == request.auth.uid || isGlobalAdmin()))
        ))
      );

      allow delete: if isGlobalAdmin();

      // Subcollections (Pillar 1)
      match /audit/{logId} {
        allow read: if isSignedIn() && canUserViewCase(get(/databases/$(database)/documents/cases/$(caseId)).data);
        allow create: if isSignedIn() || (!isSignedIn() && incoming().userId == 'anonymous');
      }

      match /actors/{actorId} {
        allow read: if isSignedIn() && canUserViewCase(get(/databases/$(database)/documents/cases/$(caseId)).data);
        allow write: if isSignedIn() && (
          get(/databases/$(database)/documents/cases/$(caseId)).data.assignedToUid == request.auth.uid ||
          isGlobalAdmin()
        );
      }

      match /contributions/{contribId} {
        allow read: if isSignedIn() && canUserViewCase(get(/databases/$(database)/documents/cases/$(caseId)).data);
        allow create: if isSignedIn() && (
          // Investigator can create
          get(/databases/$(database)/documents/cases/$(caseId)).data.assignedToUid == request.auth.uid ||
          // Or a member of the assigned team
          (get(/databases/$(database)/documents/cases/$(caseId)).data.get('assignedTeam', '') != '' && 
           get(/databases/$(database)/documents/cases/$(caseId)).data.assignedTeam == getUserData().get('team', 'none'))
        );
        allow update, delete: if isSignedIn() && (
          incoming().authorUid == request.auth.uid || 
          isGlobalAdmin() ||
          get(/databases/$(database)/documents/cases/$(caseId)).data.assignedToUid == request.auth.uid
        );
      }

      match /actions/{actionId} {
        allow read: if isSignedIn() && canUserViewCase(get(/databases/$(database)/documents/cases/$(caseId)).data);
        allow write: if isSignedIn() && (
          get(/databases/$(database)/documents/cases/$(caseId)).data.assignedToUid == request.auth.uid ||
          isGlobalAdmin()
        );
      }
    }

    // --- NOTIFICATIONS ---
    match /notifications/{noteId} {
      allow read: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.recipientUid == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isSignedIn(); 
      allow delete: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
    }

    // --- GLOBAL AUDIT ---
    match /AuditLog/{logId} {
      allow read: if isGlobalAdmin();
      allow create: if isSignedIn();
    }
  }
}
